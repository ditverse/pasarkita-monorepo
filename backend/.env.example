# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# JWT
JWT_SECRET=your_jwt_secret

# API Gateway
GATEWAY_BASE_URL=https://gateway.vercel.app/api
GATEWAY_API_KEY=your_gateway_api_key

# Integrasi langsung (override Gateway — pakai untuk mock lokal)
# Development: arahkan ke mock server
# Mock development lokal saja. Pada NODE_ENV selain development, aplikasi selalu
# memakai GATEWAY_BASE_URL sesuai aturan tugas besar.
SMARTBANK_URL=http://localhost:4001/smartbank
LOGISTIKITA_URL=http://localhost:4002/logistikita

# App
NODE_ENV=development
PORT=3001
